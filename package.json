{
  "name": "@serphouse/serphouse-nodejs",
  "version": "2.0.0",
  "description": "Automate your search engines (Google, Bing, Yahoo) result (serp api) using Serphouse.com API client and retrive in structured JSON format.",
  "main": "lib/SERPHouse/index.js",
  "types": "lib/SERPHouse/index.d.ts",
  "files": [
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node lib/SERPHouse/index.js",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "lint": "eslint src/",
    "format": "npx prettier --write \"src/**/*.ts\""
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/SERPHouse/serphouse-nodejs.git"
  },
  "keywords": [
    "Serp",
