    "api",
    "client",
    "curl",
    "JSON",
    "XML",
    "datamining",
    "ml",
    "learning",
    "scrape"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SERPHouse/serphouse-nodejs/issues"
  },
  "homepage": "https://github.com/SERPHouse/serphouse-nodejs#readme",
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.0"
  }
}
